<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bnc.mapper.AuthMapper">
	<select id="selectList" resultType="com.bnc.domain.TestDTO">
		SELECT * FROM tbl_test
	</select>
	<!-- Admin Login -->
	<select id="adminLoginSelect" resultType="int">
		SELECT count(admin_id) FROM bnc_admin 
			WHERE admin_id = #{admin_id} and admin_password = #{admin_password}
	</select>
</mapper>